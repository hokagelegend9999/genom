#!/bin/bash

# ===============================================
# Cloudflare SSL Configurer Script (DNS-01 method)
# ===============================================

XRAY_CONFIG_DIR="$1"
XRAY_TLS_DIR="$2"
ADMIN_EMAIL="$3"
CLOUDFLARE_API_KEY="$4"
FULL_DOMAIN="$5"
XRAY_BIN_PATH="$6"
XRAY_LOG_DIR="$7"
MY_PUBLIC_IP="$8"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

print_status() { echo -e "\n${YELLOW}>>> $1${NC}"; }
print_error() { echo -e "${RED}!!! ERROR: $1${NC}" >&2; exit 1; }

print_status "Executing Cloudflare SSL Configuration..."

ACME_SH_CMD="$HOME/.acme.sh/acme.sh"
[ -f "$ACME_SH_CMD" ] || print_error "acme.sh not found. It must be installed first."

# Export Cloudflare credentials
export CF_Key="$CLOUDFLARE_API_KEY"
export CF_Email="$ADMIN_EMAIL"
[ -z "$CF_Key" ] && print_error "Cloudflare API Key is empty."

# Set Let's Encrypt as default CA
"$ACME_SH_CMD" --set-default-ca --server letsencrypt || print_error "Failed to set CA."

# Issue certificate using Cloudflare DNS
print_status "Issuing SSL certificate for $FULL_DOMAIN using DNS-01 challenge..."
"$ACME_SH_CMD" --issue --dns dns_cf -d "$FULL_DOMAIN" || {
    print_error "Certificate issue failed. Check Cloudflare API and domain."
    print_error "Try: $ACME_SH_CMD --issue --dns dns_cf -d $FULL_DOMAIN --debug"
    exit 1
}

# Cleanup sensitive env
unset CF_Key
unset CF_Email

# Install certificate
sudo mkdir -p "$XRAY_TLS_DIR"
"$ACME_SH_CMD" --install-cert -d "$FULL_DOMAIN" \
--key-file "$XRAY_TLS_DIR/private.key" \
--fullchain-file "$XRAY_TLS_DIR/fullchain.pem" \
--reloadcmd "sudo systemctl restart xray.service" || print_error "Failed to install certificate."

# Set permissions
sudo chown www-data:www-data "$XRAY_TLS_DIR/private.key" "$XRAY_TLS_DIR/fullchain.pem"
sudo chmod 600 "$XRAY_TLS_DIR/private.key"
sudo chmod 644 "$XRAY_TLS_DIR/fullchain.pem"

# Update config.json
print_status "Updating XRAY config with certificate paths..."
CONFIG_PATH="$XRAY_CONFIG_DIR/config.json"
CONFIG_ORIG=$(sudo cat "$CONFIG_PATH")

UPDATED_CONFIG=$(echo "$CONFIG_ORIG" | jq \
--arg cert "${XRAY_TLS_DIR}/fullchain.pem" \
--arg key "${XRAY_TLS_DIR}/private.key" \
--arg domain "$FULL_DOMAIN" '
(.inbounds[] | select(.port == 443 and .protocol == "vless") |
.streamSettings.tlsSettings.certificates[0].certificateFile) = $cert |
(.inbounds[] | select(.port == 443 and .protocol == "vless") |
.streamSettings.tlsSettings.certificates[0].keyFile) = $key |
(.inbounds[] | select(.port == 443 and .protocol == "vless") |
.streamSettings.tlsSettings.serverName) = $domain |
(.inbounds[] | select(.port == 443 and .protocol == "vless") |
.streamSettings.wsSettings.headers.Host) = $domain
') || print_error "Failed to modify config.json"

echo "$UPDATED_CONFIG" | sudo tee "$CONFIG_PATH" >/dev/null || print_error "Failed to save config."

print_status "✅ Cloudflare SSL Configuration Complete!"
