# --- Install Vnstat (Adjusted for modern Vnstat usage) ---
function ins_vnstat(){
clear
print_install "Menginstall Vnstat"
apt -y install vnstat > /dev/null 2>&1
systemctl restart vnstat || /etc/init.d/vnstat restart # Menggunakan systemctl
apt -y install libsqlite3-dev > /dev/null 2>&1

# Membangun dari source jika perlu, tapi apt install biasanya sudah cukup
# Jika apt install vnstat sudah menginstal versi terbaru yang dibutuhkan, bagian ini bisa dilewati.
# Jika Anda tetap ingin membangun dari source, pastikan dependensi build terpenuhi.
# wget https://humdi.net/vnstat/vnstat-2.6.tar.gz
# tar zxvf vnstat-2.6.tar.gz
# cd vnstat-2.6
# ./configure --prefix=/usr --sysconfdir=/etc && make && make install
# cd

# Mendapatkan nama antarmuka jaringan utama secara otomatis
NET=$(ip -o -4 route show to default | awk '{print $5}' | head -n 1)
if [ -z "$NET" ]; then
    print_error "Could not detect primary network interface. Vnstat may not work correctly."
    NET="eth0" # Fallback
fi

vnstat -u -i "$NET"
sed -i "s/Interface \"\"eth0\"\"/Interface \"\"<span class="math-inline">NET\\"\\"/g" /etc/vnstat\.conf
chown vnstat\:vnstat /var/lib/vnstat \-R
systemctl enable vnstat
systemctl restart vnstat
systemctl status vnstat
rm \-f /root/vnstat\-2\.6\.tar\.gz 2\>/dev/null
rm \-rf /root/vnstat\-2\.6 2\>/dev/null
print\_success "Vnstat"
\}
\# \-\-\- Install Backup \(Adjusted\) \-\-\-
function ins\_backup\(\)\{
clear
print\_install "Memasang Backup Server"
\#BackupOption
apt install rclone \-y
printf "q\\n" \| rclone config \# Ini akan membuat rclone config kosong, perlu diisi secara manual atau dengan file
wget \-O /root/\.config/rclone/rclone\.conf "</span>{REPO}Data/rclone.conf" # Path standar rclone config
# Install Wondershaper
cd /bin
# Menggunakan wget atau curl langsung karena git clone akan menempatkan di /bin/wondershaper
wget -q --retry 5 --retry-delay 5 https://raw.githubusercontent.com/magnific0/wondershaper/master/wondershaper -O /usr/local/sbin/wondershaper
chmod +x /usr/local/sbin/wondershaper
wget -q --retry 5 --retry-delay 5 https://raw.githubusercontent.com/magnific0/wondershaper/master/wondershaper.conf -O /etc/wondershaper.conf # Jika ada config file
cd /root # Kembali ke root
rm -rf wondershaper # Hapus direktori jika ada
echo > /home/limit # File kosong untuk limit
apt install msmtp-mta ca-certificates bsd-mailx -y

# Konfigurasi msmtp (PASTIKAN PASSWORD GMAIL INI TIDAK EXPOSED DI GITHUB PUBLIK!)
# Ini adalah risiko keamanan yang sangat besar jika skrip ini publik.
# Pertimbangkan menggunakan variabel lingkungan atau input user.
# Untuk Gmail, Anda mungkin perlu App Password jika 2FA diaktifkan.
cat<<EOF>>/etc/msmtprc
defaults
tls on
tls_starttls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt

account default
host smtp.gmail.com
port 587
auth on
user oceantestdigital@gmail.com
from oceantestdigital@gmail.com
password jokerman77
logfile ~/.msmtp.log
EOF
chown -R root:root /etc/msmtprc # Lebih aman root:root, bukan www-data:www-data untuk file config mail
chmod 600 /etc/msmtprc # Hanya dapat dibaca oleh root

wget -q -O /etc/ipserver "<span class="math-inline">\{REPO\}Data/ipserver" && bash /etc/ipserver \# Pastikan script ipserver kompatibel
print\_success "Backup Server"
\}
clear
\# \-\-\- Install Swap \(No significant changes needed, gotop path adjusted\) \-\-\-
function ins\_swab\(\)\{
clear
print\_install "Memasang Swap 1 G"
gotop\_latest\="</span>(curl -sS --max-time 10 https://api.github.com/repos/xxxserxxx/gotop/releases | grep tag_name | sed -E 's/.*"v(.*)".*/\1/' | head -n 1)"
    gotop_link="https://github.com/xxxserxxx/gotop/releases/download/v${gotop_latest}/gotop_v${gotop_latest}_linux_amd64.deb"
    
    # Download gotop
    if ! curl -sL --max-time 10 "<span class="math-inline">gotop\_link" \-o /tmp/gotop\.deb; then
print\_error "Failed to download gotop\. Continuing without it\."
else
dpkg \-i /tmp/gotop\.deb \>/dev/null 2\>&1
rm \-f /tmp/gotop\.deb
fi
\# \> Buat swap sebesar 1G
dd if\=/dev/zero of\=/swapfile bs\=1M count\=1024 \# Menggunakan bs\=1M lebih cepat
mkswap /swapfile
chown root\:root /swapfile
chmod 0600 /swapfile \>/dev/null 2\>&1
swapon /swapfile \>/dev/null 2\>&1
sed \-i '</span> i\/swapfile               swap                    swap    defaults        0 0' /etc/fstab

    # > Singkronisasi jam (chrony sudah diatur sebelumnya)
    chronyd -q 'server 0.id.pool.ntp.org iburst' # Menggunakan server NTP Indonesia
    chronyc sourcestats -v
    chronyc tracking -v
    
    # Install BBR
    wget -q --retry 5 --retry-delay 5 "<span class="math-inline">\{REPO\}Data/bbr\.sh" && chmod \+x bbr\.sh && \./bbr\.sh
rm \-f bbr\.sh \# Hapus script bbr setelah dijalankan
print\_success "Swap 1 G & BBR"
\}
