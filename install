rm -f /root/README.md 2>/dev/null || true
rm -f /root/domain || true # Sudah dihapus di fungsi pasang_domain

# Set hostname
# username didapatkan dari izinsc, pastikan sudah terdefinisi
if [ -n "$username" ]; then
    sudo hostnamectl set-hostname "$username" || print_error "Failed to set hostname."
else
    print_error "Username not defined, skipping hostname change."
fi
secs_to_human "$(($(date +%s) - ${start}))"

