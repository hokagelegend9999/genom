# --- Install Vnstat (Adjusted for modern Vnstat usage) ---
function ins_vnstat(){
clear
print_install "Menginstall Vnstat"
apt -y install vnstat > /dev/null 2>&1 || print_error "Failed to install vnstat."
systemctl restart vnstat.service || /etc/init.d/vnstat restart || true # Menggunakan systemctl
apt -y install libsqlite3-dev > /dev/null 2>&1 || print_error "Failed to install libsqlite3-dev."

# Mendapatkan nama antarmuka jaringan utama secara otomatis
NET=$(ip -o -4 route show to default | awk '{print $5}' | head -n 1)
if [ -z "$NET" ]; then
    print_error "Could not detect primary network interface. Vnstat may not work correctly."
    NET="eth0" # Fallback
fi

vnstat -u -i "$NET" || true # Menambah || true
sed -i "s/Interface \"\"eth0\"\"/Interface \"\"${NET}\"\"/g" /etc/vnstat.conf || true
chown vnstat:vnstat /var/lib/vnstat -R || true
systemctl enable vnstat.service || true
systemctl restart vnstat.service || true
systemctl status vnstat.service || true
rm -f /root/vnstat-2.6.tar.gz 2>/dev/null || true
rm -rf /root/vnstat-2.6 2>/dev/null || true
print_success "Vnstat"
}

# --- Install Backup (Cleaned and Adjusted) ---
function ins_backup(){
clear
print_install "Memasang Backup Server"
#BackupOption
apt install rclone -y || print_error "Failed to install rclone."
printf "n\n" | rclone config # Menggunakan 'n' untuk tidak mengkonfigurasi apa pun, hindari 'q' yang bisa membuat error

wget -O /root/.config/rclone/rclone.conf "${REPO}Data/rclone.conf" || print_error "Failed to download rclone config."
chmod 600 /root/.config/rclone/rclone.conf # Permission yang lebih aman

# Install Wondershaper
# Wondershaper adalah script, tidak perlu git clone dan make install.
wget -q --retry 5 --retry-delay 5 https://raw.githubusercontent.com/magnific0/wondershaper/master/wondershaper -O /usr/local/sbin/wondershaper || print_error "Failed to download wondershaper script."
chmod +x /usr/local/sbin/wondershaper
wget -q --retry 5 --retry-delay 5 https://raw.githubusercontent.com/magnific0/wondershaper/master/wondershaper.conf -O /etc/wondershaper.conf || print_error "Failed to download wondershaper config." # Jika ada config file
chmod 644 /etc/wondershaper.conf || true

echo > /home/limit # File kosong untuk limit
apt install msmtp-mta ca-certificates bsd-mailx -y || print_error "Failed to install msmtp dependencies."

# Konfigurasi msmtp
# !!! PERINGATAN KEAMANAN KRITIS !!!
# Password Gmail di sini akan terekspos jika skrip ini publik.
# SANGAT DISARANKAN untuk:
# 1. Menggunakan App Password dari Google jika 2FA diaktifkan.
# 2. Meminta pengguna untuk memasukkan password saat instalasi, bukan hardcode.
# 3. Menggunakan layanan email transaksional khusus (misalnya Mailgun, SendGrid) dengan API key.
# Saya biarkan untuk fungsionalitas, tapi Anda harus menyadari risikonya.
cat<<EOF>>/etc/msmtprc
defaults
tls on
tls_starttls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt

account default
host smtp.gmail.com
port 587
auth on
user oceantestdigital@gmail.com
from oceantestdigital@gmail.com
password jokerman77
logfile ~/.msmtp.log
EOF
chown -R root:root /etc/msmtprc # Lebih aman root:root, bukan www-data:www-data untuk file config mail
chmod 600 /etc/msmtprc # Hanya dapat dibaca oleh root

wget -q -O /etc/ipserver "${REPO}Data/ipserver" && bash /etc/ipserver || print_error "Failed to install ipserver script." # Pastikan script ipserver kompatibel
print_success "Backup Server"
}

# --- Install Swap (Cleaned and Adjusted) ---
function ins_swab(){
clear
print_install "Memasang Swap 1 G"
gotop_latest=$(curl -sS --max-time 10 https://api.github.com/repos/xxxserxxx/gotop/releases | grep tag_name | sed -E 's/.*"v(.*)".*/\1/' | head -n 1)
gotop_link="https://github.com/xxxserxxx/gotop/releases/download/v${gotop_latest}/gotop_v${gotop_latest}_linux_amd64.deb"
    
    # Download gotop
    if ! curl -sL --max-time 10 "$gotop_link" -o /tmp/gotop.deb; then
print_error "Failed to download gotop. Continuing without it."
else
dpkg -i /tmp/gotop.deb >/dev/null 2>&1 || print_error "Failed to install gotop deb package."
rm -f /tmp/gotop.deb || true
fi

# > Buat swap sebesar 1G
dd if=/dev/zero of=/swapfile bs=1M count=1024 || print_error "Failed to create swapfile." # Menggunakan bs=1M lebih cepat
mkswap /swapfile || print_error "Failed to format swapfile."
chown root:root /swapfile || print_error "Failed to set swapfile ownership."
chmod 0600 /swapfile >/dev/null 2>&1 || print_error "Failed to set swapfile permissions."
swapon /swapfile >/dev/null 2>&1 || print_error "Failed to enable swapfile."
sed -i '$ i\/swapfile               swap               swap    defaults        0 0' /etc/fstab || print_error "Failed to add swap to fstab."

    # > Singkronisasi jam (chrony sudah diatur sebelumnya)
    chronyd -q 'server 0.id.pool.ntp.org iburst' || true # Menggunakan server NTP Indonesia
    chronyc sourcestats -v || true
    chronyc tracking -v || true
    
    # Install BBR
    wget -q --retry 5 --retry-delay 5 "${REPO}Data/bbr.sh" -O /tmp/bbr.sh && chmod +x /tmp/bbr.sh && /tmp/bbr.sh || print_error "Failed to install BBR."
rm -f /tmp/bbr.sh || true # Hapus script bbr setelah dijalankan
print_success "Swap 1 G & BBR"
}

