# --- Install ePro WebSocket Proxy (Cleaned and Adjusted) ---
function ins_epro(){
clear
print_install "Menginstall ePro WebSocket Proxy"
    wget -O /usr/bin/ws "${REPO}Data/ws" >/dev/null 2>&1 || print_error "Failed to download ws binary."
wget -O /usr/bin/tun.conf "${REPO}Data/tun.conf" >/dev/null 2>&1 || print_error "Failed to download tun.conf."
    wget -O /etc/systemd/system/ws.service "${REPO}Data/ws.service" >/dev/null 2>&1 || print_error "Failed to download ws.service."
chmod +x /etc/systemd/system/ws.service
chmod +x /usr/bin/ws
chmod 644 /usr/bin/tun.conf
systemctl disable ws.service || true
systemctl stop ws.service || true
systemctl enable ws.service || true
systemctl start ws.service || true
systemctl restart ws.service || true

# Mengunduh geosite.dat dan geoip.dat
# Pastikan ini adalah link terbaru dan valid
wget -q -O /usr/local/share/xray/geosite.dat "https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geosite.dat" >/dev/null 2>&1 || print_error "Failed to download geosite.dat."
wget -q -O /usr/local/share/xray/geoip.dat "https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat" >/dev/null 2>&1 || print_error "Failed to download geoip.dat."

wget -O /usr/sbin/ftvpn "${REPO}Data/ftvpn" >/dev/null 2>&1 || print_error "Failed to download ftvpn."
chmod +x /usr/sbin/ftvpn

# Aturan IPtables untuk memblokir torrent (tetap dipertahankan, tapi catat batasan)
iptables -A FORWARD -m string --string "get_peers" --algo bm -j DROP || true
iptables -A FORWARD -m string --string "announce_peer" --algo bm -j DROP || true
iptables -A FORWARD -m string --string "find_node" --algo bm -j DROP || true
iptables -A FORWARD -m string --algo bm --string "BitTorrent" -j DROP || true
iptables -A FORWARD -m string --algo bm --string "BitTorrent protocol" -j DROP || true
iptables -A FORWARD -m string --algo bm --string "peer_id=" -j DROP || true
iptables -A FORWARD -m string --algo bm --string ".torrent" -j DROP || true
iptables -A FORWARD -m string --algo bm --string "announce.php?passkey=" -j DROP || true
iptables -A FORWARD -m string --algo bm --string "torrent" -j DROP || true
iptables -A FORWARD -m string --algo bm --string "announce" -j DROP || true
iptables -A FORWARD -m string --algo bm --string "info_hash" -j DROP || true

iptables-save > /etc/iptables.up.rules || true
iptables-restore -t < /etc/iptables.up.rules || true
netfilter-persistent save || true
netfilter-persistent reload || true

# remove unnecessary files
cd /root || exit # Pastikan di direktori root sebelum autoclean/autoremove
apt autoclean -y >/dev/null 2>&1 || true
apt autoremove -y >/dev/null 2>&1 || true
print_success "ePro WebSocket Proxy"
}

# --- Restart Services (Adjusted) ---
function ins_restart(){
clear
print_install "Restarting All Services"
# Menggunakan systemctl untuk semua layanan
systemctl restart nginx.service || /etc/init.d/nginx restart || true
systemctl restart sshd.service || /etc/init.d/ssh restart || true # Menggunakan sshd
systemctl restart dropbear.service || /etc/init.d/dropbear restart || true
systemctl restart fail2ban.service || /etc/init.d/fail2ban restart || true
systemctl restart vnstat.service || /etc/init.d/vnstat restart || true
systemctl restart cron.service || /etc/init.d/cron restart || true
systemctl daemon-reload || true
systemctl start netfilter-persistent.service || true
systemctl enable --now nginx.service || true
systemctl enable --now xray.service || true
systemctl enable --now rc-local.service || true
systemctl enable --now dropbear.service || true
systemctl enable --now cron.service || true
systemctl enable --now haproxy.service || true # Pastikan haproxy sudah diinstall dan ada unit filenya
systemctl enable --now netfilter-persistent.service || true
systemctl enable --now ws.service || true
systemctl enable --now fail2ban.service || true
history -c
echo "unset HISTFILE" >> /etc/profile

cd /root || exit # Pastikan di direktori root sebelum menghapus file
rm -f /root/openvpn || true # Jika ini adalah file yang perlu dihapus setelah instalasi
rm -f /root/key.pem || true # Jika ini adalah file yang perlu dihapus setelah instalasi
rm -f /root/cert.pem || true # Jika ini adalah file yang perlu dihapus setelah instalasi
print_success "All Services"
}

# --- Install Menu (No changes needed, assuming menu.zip structure is consistent) ---
function menu(){
    clear
    print_install "Memasang Menu Packet"
    wget "${REPO}Menu/menu.zip" -O /tmp/menu.zip || print_error "Failed to download menu.zip."
    if [ ! -f /tmp/menu.zip ]; then
        print_error "Failed to download menu.zip. Menu will not be installed."
        return 1
    fi
    unzip -o /tmp/menu.zip -d /tmp/menu_temp || print_error "Failed to unzip menu.zip." # Unzip ke direktori sementara
    chmod +x /tmp/menu_temp/*
    mv /tmp/menu_temp/* /usr/local/sbin/ || print_error "Failed to move menu files."
    rm -rf /tmp/menu_temp || true
    rm -f /tmp/menu.zip || true
    print_success "Menu Packet"
}

# --- Create Default Profile & Cron Jobs (Cleaned and Adjusted) ---
function profile(){
clear
    cat >/root/.profile <<EOF
# ~/.profile: executed by Bourne-compatible login shells.
if [ "\$BASH" ]; then
    if [ -f ~/.bashrc ]; then
        . ~/.bashrc
    fi
fi
mesg n || true
menu # Memastikan 'menu' dijalankan saat login
EOF
mkdir -p /root/.info
curl -sS "ipinfo.io/org?token=7a814b6263b02c" > /root/.info/.isp || true
curl -sS "ipinfo.io/city?token=7a814b6263b02c" > /root/.info/.city || true # Pindahkan ini ke sini juga
# Cron jobs
# Pastikan semua script yang dipanggil di cron job ada dan executable di /usr/local/sbin
cat >/etc/cron.d/xp_all <<-EOF
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
2 0 * * * root /usr/local/sbin/xp
# 2 0 * * * root /usr/local/sbin/menu # Apakah ini perlu diulang setiap hari? Mungkin tidak.
EOF
cat >/etc/cron.d/logclean <<-EOF
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
*/20 * * * * root /usr/local/sbin/clearlog
EOF
chmod 644 /root/.profile # Permission yang lebih aman
cat >/etc/cron.d/daily_reboot <<-EOF
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
0 5 * * * root /sbin/reboot
EOF
cat >/etc/cron.d/limit_ip <<-EOF
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
*/2 * * * * root /usr/local/sbin/limit-ip
EOF
cat >/etc/cron.d/lim-ip-ssh <<-EOF
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
*/1 * * * * root /usr/local/sbin/limit-ip-ssh
EOF
cat >/etc/cron.d/limit_ip2 <<-EOF
SHELL=/bin/sh
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
*/2 * * * * root /usr/bin/limit-ip # Duplikat dari limit_ip? Periksa.
EOF
echo "*/1 * * * * root echo -n > /var/log/nginx/access.log" >/etc/cron.d/log.nginx
echo "*/1 * * * * root echo -n > /var/log/xray/access.log" >>/etc/cron.d/log.xray
service cron restart || true # Pastikan ini berhasil
cat >/home/daily_reboot <<-EOF
5
EOF
# rc-local.service sudah didefinisikan di fungsi ssh(), ini duplikasi.
echo "/bin/false" >>/etc/shells
echo "/usr/sbin/nologin" >>/etc/shells
# rc.local file
cat >/etc/rc.local <<EOF
#!/bin/sh -e
# rc.local
# By default this script does nothing.
iptables -I INPUT -p udp --dport 5300 -j ACCEPT
iptables -t nat -I PREROUTING -p udp --dport 53 -j REDIRECT --to-ports 5300
systemctl restart netfilter-persistent.service || true # Ini akan dijalankan setiap boot.
exit 0
EOF
chmod +x /etc/rc.local
    
# AUTOREB logic (No changes needed)
AUTOREB=$(cat /home/daily_reboot)
    SETT=11
    if [ "$AUTOREB" -gt "$SETT" ]; then
        TIME_DATE="PM"
    else
        TIME_DATE="AM"
    fi
print_success "Menu Packet & Cron Jobs"
}

# --- Enable Services (Adjusted) ---
function enable_services(){
clear
print_install "Enable Service"
    systemctl daemon-reload || true
    systemctl start netfilter-persistent.service || true
    systemctl enable --now rc-local.service || true
    systemctl enable --now cron.service || true
    systemctl enable --now netfilter-persistent.service || true
    systemctl restart nginx.service || true
    systemctl restart xray.service || true
    systemctl restart cron.service || true
    systemctl enable --now nginx.service || true
    systemctl enable --now xray.service || true
    systemctl enable --now dropbear.service || true
    systemctl enable --now haproxy.service || true # Pastikan haproxy terinstal dan unit filenya ada
    systemctl enable --now ws.service || true
    systemctl enable --now fail2ban.service || true
    print_success "Enable Service"
    clear
}

# --- Main Install Function ---
function instal(){
clear
    first_setup
    nginx_install
    base_package
    make_folder_xray
    pasang_domain
    password_default # Pastikan fungsi ini didefinisikan
    pasang_ssl
    install_xray
    ssh
    udp_mini
    ssh_slow
    ins_udpSSH
    ins_SSHD
    ins_dropbear
    ins_vnstat
    ins_backup
    ins_swab
    ins_Fail2ban
    ins_epro
    ins_restart
    menu
    profile
    enable_services
    restart_system # Memanggil restart_system di akhir
}

# --- Execute Installation ---
instal

echo ""
history -c
rm -f /root/menu || true # Sudah dihapus di fungsi menu
rm -f /root/*.zip || true # Menghapus semua file zip
rm -f /root/*.sh || true # Menghapus semua file .sh
