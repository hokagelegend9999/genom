# --- Restart System & Telegram Notification (Cleaned and Adjusted for Robustness) ---
function restart_system(){
#IZIN SCRIPT
print_install "Sending Installation Notification & Setting Hostname"
# Menggunakan curl --retry untuk ketahanan jaringan
curl --retry 5 --retry-delay 5 "ipinfo.io/org?token=7a814b6263b02c" > /root/.isp || echo "Unknown ISP" > /root/.isp
curl --retry 5 --retry-delay 5 "ipinfo.io/city?token=7a814b6263b02c" > /root/.city || echo "Unknown City" > /root/.city
MYIP=$(curl -sS --max-time 10 ipv4.icanhazip.com || curl -sS --max-time 10 checkip.amazonaws.com || curl -sS --max-time 10 ifconfig.me)

echo -e "\e[32mloading...\e[0m"
clear

# Pastikan URL izinsc masih valid dan isinya sesuai
izinsc="https://github.com/hokagelegend9999/ijin/raw/refs/heads/main/gnome"

# USERNAME
rm -f /usr/bin/user
username=$(curl -sS --max-time 10 "$izinsc" | grep "$MYIP" | awk '{print $2}')
echo "$username" >/usr/bin/user || echo "unknown_user" > /usr/bin/user
expx=$(curl -sS --max-time 10 "$izinsc" | grep "$MYIP" | awk '{print $3}')
echo "$expx" >/usr/bin/e || echo "unknown_exp" > /usr/bin/e

# DETAIL ORDER
username=$(cat /usr/bin/user)
oid=$(cat /usr/bin/ver 2>/dev/null || echo "N/A") # Tambahkan 2>/dev/null untuk menghindari error jika file tidak ada
exp=$(cat /usr/bin/e)
clear

# Status Expired Active
Info="(${green}Active${NC})"
Error="(${RED}ExpiRED${NC})"
today=$(date +"%Y-%m-%d") # Menggunakan date langsung
Exp1=$(curl -sS --max-time 10 "$izinsc" | grep "$MYIP" | awk '{print $4}')
if [[ "$today" < "$Exp1" ]]; then # Baris ini dikoreksi dari span HTML
    sts="${Info}"                 # Baris ini dikoreksi dari span HTML
else
    sts="${Error}"
fi

# Telegram Notification
TIMES="10"
CHATID="1469244768"
KEY="7219522943:AAFZGZIbRU-CodrmgGJRuyXCV55sJDOSrSg" # PENTING: JANGAN BIARKAN API KEY TERBOCOR!
URL="https://api.telegram.org/bot${KEY}/sendMessage" # URL harus di dalam kutip
ISP=$(cat /root/.isp)
IP_NOTIF=$(curl -sS --max-time 10 ipv4.icanhazip.com) # Gunakan nama variabel berbeda agar tidak bentrok
CITY=$(cat /root/.city)
TIMEZONE=$(TZ='Asia/Jakarta' printf '%(%H:%M:%S)T') # Pastikan timezone benar

TEXT="
<code>────────────────────</code>
<b>⚡𝗡𝗢𝗧𝗜𝗙 𝗜𝗡𝗦𝗧𝗔𝗟𝗟 𝗦𝗖𝗥𝗜𝗣𝗧⚡</b>
<code>────────────────────</code>
<code>User      :</code><code>${username}</code>
<code>ISP       :</code><code>${ISP}</code>
<code>CITY      :</code><code>${CITY}</code>
<code>IP        :</code><code>${IP_NOTIF}</code>
<code>DATE      :</code><code>${DATE}</code>
<code>Time      :</code><code>${TIMEZONE}</code>
<code>Exp Sc.   :</code><code>${exp}</code>
<code>─────────────────────────────</code>
<b>HOKAGE CENTER VPN STORE SCRIPT</b>
<code>─────────────────────────────</code>
<i>Automatic Notifications From Github</i>
"
# Menggunakan jq untuk membuat JSON payload yang lebih rapi dan aman
# Memastikan jq terinstal di base_package
JSON_PAYLOAD=$(jq -n \
    --arg chat_id "$CHATID" \
    --arg text "$TEXT" \
    --arg parse_mode "html" \
    --argjson reply_markup '{"inline_keyboard":[[{"text":"ᴏʀᴅᴇʀ","url":"t.me/hokagelegend1"}]]}' \
