# --- Install Dropbear (Adjusted for systemctl preference and config) ---
function ins_dropbear(){
clear
print_install "Menginstall Dropbear"
apt-get install dropbear -y > /dev/null 2>&1 || print_error "Failed to install dropbear."

# Unduh konfigurasi dropbear.conf
wget -q -O /etc/default/dropbear "https://raw.githubusercontent.com/hokagelegend9999/genom/refs/heads/main/Data/dropbear.conf" || print_error "Failed to download dropbear config."
chmod 644 /etc/default/dropbear # Permission yang lebih aman

# Penting: Konfigurasi port Dropbear.
# Jika port 22 sudah dipakai OpenSSH, Dropbear harus di port lain.
# Dropbear config dari repo Anda: https://raw.githubusercontent.com/hokagelegend9999/genom/refs/heads/main/Data/dropbear.conf
# File tersebut biasanya berisi:
# DROPBEAR_PORT=109
# DROPBEAR_EXTRA_ARGS="-p 143"
# Ini berarti Dropbear akan mencoba mendengarkan di port 109 dan 143. Pastikan tidak bentrok.
# Jika ada masalah, cek DROPBEAR_PORT dan DROPBEAR_EXTRA_ARGS di file tersebut.

systemctl restart dropbear.service || /etc/init.d/dropbear restart || true # Menggunakan systemctl lebih dulu
systemctl status dropbear.service || /etc/init.d/dropbear status || true # Menggunakan systemctl lebih dulu

# Periksa status Dropbear setelah restart
if systemctl is-active --quiet dropbear.service; then
    print_success "Dropbear"
else
    print_error "Dropbear failed to start. Check /etc/default/dropbear and ensure ports 109/143 are free."
    systemctl status dropbear.service --no-pager
fi
}

