#!/bin/bash

# ===============================================
# XRAY Installation & Configuration Script (FINAL)
# (VLESS over WebSocket with TLS on Port 443)
# ===============================================

# --- Global Variables ---
XRAY_BIN_PATH="/usr/local/bin/xray"
XRAY_CONFIG_DIR="/etc/xray"
XRAY_LOG_DIR="/var/log/xray"
XRAY_TLS_DIR="/etc/xray/tls"
XRAY_SERVICE_FILE="/etc/systemd/system/xray.service"
MENU_SCRIPT_PATH="/usr/local/bin/xray_menu"

BASE_DOMAIN="hokageyoutube.my.id"
CLOUDFLARE_API_KEY="ab8d0901acb186291e58f21359d07e7b847dc"
ADMIN_EMAIL="faridaumiabi@gmail.com"
TELEGRAM_BOT_TOKEN="7219522943:AAFZGZIbRU-CodrmgGJRuyXCV55sJDOSrSg"
TELEGRAM_CHAT_ID="1469244768"

MY_PUBLIC_IP=""
SUBDOMAIN=""
FULL_DOMAIN=""

# --- Download Scripts ---
download_script () {
  local url="$1" outfile="$2"
  if [[ ! -f "$outfile" ]]; then
    echo "• Mengunduh $outfile …"
    wget -q "$url" -O "$outfile"
    chmod +x "$outfile"
  fi
}

download_script "https://github.com/hokagelegend9999/genom/raw/refs/heads/main/xray" xray
download_script "https://github.com/hokagelegend9999/genom/raw/refs/heads/main/cloudflare" cloudflare
download_script "https://github.com/hokagelegend9999/genom/raw/refs/heads/main/menu" menu

XRAY_CORE_INSTALLER_SCRIPT="./xray"
CLOUDFLARE_SSL_CONFIGURER_SCRIPT="./cloudflare"
MENU_SCRIPT_INSTALLER_SCRIPT="./menu"

# --- Colors ---
RED='\033[0m\033[1;31m'
GREEN='\033[0m\033[1;32m'
YELLOW='\033[0m\033[1;33m'
NC='\033[0m'

print_header() {
    echo -e "${GREEN}=====================================================${NC}"
    echo -e "${GREEN}       XRAY MODULAR INSTALLER START                ${NC}"
    echo -e "${GREEN}=====================================================${NC}"
}

print_status() {
    echo -e "\n${YELLOW}>>> $1${NC}"
}

print_error() {
    echo -e "${RED}!!! ERROR: $1${NC}" >&2
    exit 1
}

send_telegram_notification() {
    local message="$1"
    if [ -n "$TELEGRAM_BOT_TOKEN" ] && [ -n "$TELEGRAM_CHAT_ID" ]; then
        curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage" \
            -d chat_id="$TELEGRAM_CHAT_ID" \
            -d text="$message" \
            -d parse_mode="Markdown" &>/dev/null
    else
        print_error "Telegram Bot Token or Chat ID not set. Cannot send notification."
    fi
}

install_prerequisites() {
    print_status "Installing prerequisites..."
    sudo apt update || print_error "Failed to update apt."
    sudo apt install -y curl wget unzip socat uuid-runtime jq || print_error "Failed to install prerequisites."
}

install_acme_sh() {
    print_status "Installing acme.sh..."
    if ! command -v acme.sh &>/dev/null; then
        curl https://get.acme.sh | sh || print_error "Failed to install acme.sh"
        export PATH="$HOME/.acme.sh:$PATH"
        source ~/.bashrc 2>/dev/null || true
    else
        print_status "acme.sh already installed."
    fi
}

cleanup_old_installations() {
    print_status "Cleaning up old installations..."
    sudo systemctl stop xray.service &>/dev/null || true
    sudo systemctl disable xray.service &>/dev/null || true
    sudo rm -f "$XRAY_SERVICE_FILE" "$XRAY_BIN_PATH"
    sudo rm -rf "$XRAY_CONFIG_DIR" "$XRAY_LOG_DIR"
    sudo systemctl stop haproxy nginx openvpn-server@server-tcp openvpn-server@server-udp noobzvpns.service &>/dev/null || true
    sudo systemctl disable haproxy nginx openvpn-server@server-tcp openvpn-server@server-udp noobzvpns.service &>/dev/null || true

    print_status "Verifying ports 80 and 443 are free..."
    sleep 2
    if sudo ss -tulpn | grep -E ':(80|443)'; then
        print_error "Ports 80 or 443 are still in use."
    fi
}

start_and_verify_xray_service() {
    print_status "Starting XRAY service..."
    sudo systemctl start xray.service || print_error "Failed to start XRAY service."
    sleep 5
    sudo systemctl is-active --quiet xray.service || print_error "XRAY service not running."

    print_status "Verifying XRAY is listening on port 443..."
    sudo ss -tulpn | grep -E ':(443)' | grep "xray" || print_error "XRAY is NOT listening on port 443."
}

# --- MAIN EXECUTION ---
clear
print_header

MY_PUBLIC_IP=$(curl -sS ifconfig.me)
[ -z "$MY_PUBLIC_IP" ] && print_error "Failed to detect public IP."
echo -e "${YELLOW}Detected Public IP: $MY_PUBLIC_IP${NC}"

# Subdomain selection
echo -e "\n${YELLOW}Choose your subdomain option:${NC}"
echo -e "  1. Custom subdomain"
echo -e "  2. Auto-generate"
read -p "Enter your choice (1 or 2): " SUBDOMAIN_CHOICE

if [ "$SUBDOMAIN_CHOICE" == "1" ]; then
    read -p "Enter your custom SUBDOMAIN: " SUBDOMAIN
    [ -z "$SUBDOMAIN" ] && print_error "Subdomain cannot be empty."
elif [ "$SUBDOMAIN_CHOICE" == "2" ]; then
    SUBDOMAIN=$(head /dev/urandom | tr -dc A-Za-z0-9 | head -c 8 | tr '[:upper:]' '[:lower:]')
    echo -e "${GREEN}Auto-generated Subdomain: ${YELLOW}$SUBDOMAIN${NC}"
else
    print_error "Invalid choice."
fi

FULL_DOMAIN="$SUBDOMAIN.$BASE_DOMAIN"
echo -e "Domain: $FULL_DOMAIN"
read -p "Press Enter to continue..."

sudo mkdir -p "$XRAY_CONFIG_DIR"
echo "$FULL_DOMAIN" | sudo tee "$XRAY_CONFIG_DIR/domain.txt" &>/dev/null

sudo tee "$XRAY_CONFIG_DIR/cf_api.conf" >/dev/null <<EOF
CLOUDFLARE_API_KEY="$CLOUDFLARE_API_KEY"
ADMIN_EMAIL="$ADMIN_EMAIL"
EOF
sudo chmod 600 "$XRAY_CONFIG_DIR/cf_api.conf"

install_prerequisites
install_acme_sh
cleanup_old_installations

[ ! -f "$XRAY_CORE_INSTALLER_SCRIPT" ] && print_error "XRAY script not found."
sudo bash "$XRAY_CORE_INSTALLER_SCRIPT" "$XRAY_BIN_PATH" "$XRAY_CONFIG_DIR" "$XRAY_LOG_DIR" "$XRAY_SERVICE_FILE" "$FULL_DOMAIN" "$XRAY_TLS_DIR" || print_error "XRAY Core Installation failed."

[ ! -f "$CLOUDFLARE_SSL_CONFIGURER_SCRIPT" ] && print_error "Cloudflare SSL script not found."
sudo bash "$CLOUDFLARE_SSL_CONFIGURER_SCRIPT" \
    "$XRAY_CONFIG_DIR" "$XRAY_TLS_DIR" "$ADMIN_EMAIL" "$CLOUDFLARE_API_KEY" "$FULL_DOMAIN" "$XRAY_BIN_PATH" "$XRAY_LOG_DIR" "$MY_PUBLIC_IP" || print_error "Cloudflare SSL Configuration failed."

DEFAULT_UUID_INSTALL=$(jq -r '.inbounds[] | select(.port == 443) | .settings.clients[0].id' "$XRAY_CONFIG_DIR/config.json")

[ ! -f "$MENU_SCRIPT_INSTALLER_SCRIPT" ] && print_error "Menu script not found."
sudo bash "$MENU_SCRIPT_INSTALLER_SCRIPT" "$MENU_SCRIPT_PATH" "$XRAY_CONFIG_DIR/config.json" "$XRAY_CONFIG_DIR/domain.txt" "$XRAY_BIN_PATH" "$XRAY_TLS_DIR" "$XRAY_CONFIG_DIR/cf_api.conf" || print_error "Menu Installation failed."

start_and_verify_xray_service

print_header
echo -e "XRAY Installation Complete!"
echo -e "Domain: ${YELLOW}$FULL_DOMAIN${NC}"
echo -e "UUID: ${YELLOW}$DEFAULT_UUID_INSTALL${NC}"
echo -e "Run ${YELLOW}sudo menu${NC} to manage users."

echo -e "Client Config:\nProtocol: VLESS\nPort: 443\nAddress: $FULL_DOMAIN\nUUID: $DEFAULT_UUID_INSTALL\nPath: /vlessws\nSecurity: TLS\nNetwork: ws"

echo -e "${GREEN}=====================================================${NC}"

# --- Telegram Notification ---
VPS_INFO=$(lsb_release -ds)
ARCH=$(uname -m)
HOSTNAME=$(hostname)
CPU_CORES=$(nproc)
MEM_TOTAL=$(free -h | awk '/^Mem:/ {print $2}')
DISK_USAGE=$(df -h / | awk 'NR==2 {print $5}')
CURRENT_DATE=$(date +"%Y-%m-%d %H:%M:%S %Z")
VPS_REGION="Unknown"

if curl -s http://169.254.169.254/latest/dynamic/instance-identity/document &>/dev/null; then
    VPS_REGION=$(curl -s http://169.254.169.254/latest/dynamic/instance-identity/document | grep -oP '"region"\s*:\s*"\K[^"]+')
fi

TELEGRAM_MESSAGE="*XRAY VPS Installation Success!*\n\n*Domain:* \`$FULL_DOMAIN\`\n*IP:* \`$MY_PUBLIC_IP\`\n*UUID:* \`$DEFAULT_UUID_INSTALL\`\n*Protocol:* \`VLESS/WS/TLS\`\n\n*VPS Info:*\n OS: \`$VPS_INFO\`\n Arch: \`$ARCH\`\n Hostname: \`$HOSTNAME\`\n CPU: \`$CPU_CORES\`\n RAM: \`$MEM_TOTAL\`\n Disk: \`$DISK_USAGE\`\n Region: \`$VPS_REGION\`\n Date: \`$CURRENT_DATE\`\n\n*Manage:* Run \`sudo menu\` on VPS."
send_telegram_notification "$TELEGRAM_MESSAGE"
