#!/bin/bash

# ===============================================
# XRAY Uninstaller Script
# = Menghapus semua jejak instalasi dari install_xray.sh
# ===============================================

# --- Global Variables ---
XRAY_BIN_PATH="/usr/local/bin/xray"
XRAY_CONFIG_DIR="/etc/xray"
XRAY_LOG_DIR="/var/log/xray"
XRAY_TLS_DIR="/etc/xray/tls"
XRAY_SERVICE_FILE="/etc/systemd/system/xray.service"
MENU_SCRIPT_PATH="/usr/local/bin/xray_menu"
MENU_SYMLINK_PATH="/usr/local/bin/menu"
ACME_SH_DIR="$HOME/.acme.sh" # Direktori instalasi acme.sh

# --- Colors for Output ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# --- Helper Functions ---
print_status() {
    echo -e "\n${YELLOW}>>> $1${NC}"
}

print_error() {
    echo -e "${RED}!!! ERROR: $1${NC}" >&2
}

# --- Main Uninstallation Function ---
uninstall_xray() {
    print_status "Stopping and disabling XRAY service..."
    sudo systemctl stop xray.service &>/dev/null || true
    sudo systemctl disable xray.service &>/dev/null || true

    print_status "Removing XRAY binary and config files..."
    sudo rm -f "$XRAY_BIN_PATH" || print_error "Failed to remove XRAY binary."
    sudo rm -f "$XRAY_SERVICE_FILE" || print_error "Failed to remove XRAY service file."
    sudo rm -rf "$XRAY_CONFIG_DIR" || print_error "Failed to remove XRAY config directory."
    sudo rm -rf "$XRAY_LOG_DIR" || print_error "Failed to remove XRAY log directory."
    sudo rm -rf "$XRAY_TLS_DIR" || print_error "Failed to remove XRAY TLS directory."

    print_status "Removing XRAY menu script and alias..."
    sudo rm -f "$MENU_SCRIPT_PATH" || print_error "Failed to remove menu script."
    sudo rm -f "$MENU_SYMLINK_PATH" || print_error "Failed to remove menu symlink."
    
    # Remove alias from .bashrc and .profile
    sed -i '/alias menu=\\"sudo \\/usr\\/local\\/bin\\/xray_menu\\"/d' "$HOME/.bashrc" &>/dev/null || true
    sed -i '/alias menu=\\"sudo \\/usr\\/local\\/bin\\/xray_menu\\"/d' "$HOME/.profile" &>/dev/null || true

    print_status "Cleaning up acme.sh installation (optional)..."
    if [ -d "$ACME_SH_DIR" ]; then
        "$ACME_SH_DIR/acme.sh" --uninstall &>/dev/null || true
        sudo rm -rf "$ACME_SH_DIR" || print_error "Failed to remove acme.sh directory."
    else
        echo "acme.sh directory not found, skipping removal."
    fi

    # Clean up systemd daemon
    print_status "Reloading systemd daemon..."
    sudo systemctl daemon-reload || print_error "Failed to reload systemd daemon."
    sudo systemctl reset-failed &>/dev/null || true

    print_status "Attempting to stop other services that might conflict (if still running)..."
    sudo systemctl stop haproxy &>/dev/null || true
    sudo systemctl disable haproxy &>/dev/null || true
    sudo systemctl stop nginx &>/dev/null || true
    sudo systemctl disable nginx &>/dev/null || true
    sudo systemctl stop openvpn-server@server-tcp &>/dev/null || true
    sudo systemctl stop openvpn-server@server-udp &>/dev/null || true
    sudo systemctl disable openvpn-server@server-tcp &>/dev/null || true
    sudo systemctl disable openvpn-server@server-udp &>/dev/null || true
    sudo systemctl stop noobzvpns.service &>/dev/null || true
    sudo systemctl disable noobzvpns.service &>/dev/null || true

    echo -e "\n${GREEN}=====================================================${NC}"
    echo -e "${GREEN}  XRAY Uninstallation Complete!                      ${NC}"
    echo -e "${GREEN}  Your server is now mostly clean.                   ${NC}"
    echo -e "${GREEN}  Remember to manually manage DNS records if needed. ${NC}"
    echo -e "${GREEN}=====================================================${NC}"
}

# --- Main Script Execution ---
clear
echo -e "${RED}=====================================================${NC}"
echo -e "${RED}  WARNING: This script will REMOVE XRAY and all its  ${NC}"
echo -e "${RED}           configurations from your system.          ${NC}"
echo -e "${RED}           This action is IRREVERSIBLE.              ${NC}"
echo -e "${RED}=====================================================${NC}"
read -p "Are you sure you want to proceed with uninstallation? (y/N): " CONFIRM

if [[ "$CONFIRM" =~ ^[Yy]$ ]]; then
    uninstall_xray
else
    echo -e "${YELLOW}Uninstallation cancelled.${NC}"
fi
